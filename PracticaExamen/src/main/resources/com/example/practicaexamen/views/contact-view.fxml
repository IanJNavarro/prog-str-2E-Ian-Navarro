<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.practicaexamen.controllers.ContactController">
    <padding>
        <Insets bottom="15" left="15" right="15" top="15" />
    </padding>
   <children>
      <Label text="Lista de contactos de emergencia" />
      <VBox prefHeight="241.0" prefWidth="570.0">
         <children>
            <GridPane prefHeight="100.0" prefWidth="570.0">
              <columnConstraints>
                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
              </columnConstraints>
              <rowConstraints>
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
              </rowConstraints>
               <children>
                  <TextField fx:id="txtName" promptText="Name" GridPane.columnIndex="1" />
                  <TextField fx:id="txtNum" promptText="Number" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                  <Label text="Nombre" />
                  <Label text="Telefono" GridPane.rowIndex="1" />
                  <Label text="Parentesco" GridPane.rowIndex="2" />
                  <ComboBox fx:id="cbParentesco" prefWidth="150.0" GridPane.columnIndex="1" GridPane.rowIndex="2" />
               </children>
            </GridPane>
            <ListView fx:id="listViewContacts" prefHeight="147.0" prefWidth="570.0" />
         </children>
      </VBox>
      <HBox prefHeight="41.0" prefWidth="570.0">
         <children>
            <Button onAction="#onAddContact" mnemonicParsing="false" text="Agregar" />
            <Button mnemonicParsing="false" text="Actualizar" />
            <Button mnemonicParsing="false" text="Eliminar" />
         </children>
      </HBox>
      <Label text="Label" />
   </children>
</VBox>
